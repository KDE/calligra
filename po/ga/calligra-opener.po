#: main.cpp:62
#, kde-format
msgctxt "@info"
msgid "Mimetype for <filename>%1</filename> not found!"
msgstr "Cineál MIME do <filename>%1</filename> gan aimsiú!"

#: main.cpp:118
#, kde-format
msgctxt "@action:button"
msgid "Open with <application>%1</application>"
msgstr "Oscail le <application>%1</application>"

#: main.cpp:122
#, kde-format
msgctxt "@info"
msgid ""
"Could not find Calligra application suitable for opening <filename>%1</"
"filename>.<nl/>Do you want to open the file using default application "
"<application>%2</application>?"
msgstr ""
"Níorbh fhéidir feidhmchlár Calligra a aimsiú atá oiriúnach chun <filename>"
"%1</filename> a oscailt.<nl/>Ar mhaith leat an comhad a oscailt ag baint "
"úsáide as an bhfeidhmchlár réamhshocraithe <application>%2</application>?"

#: main.cpp:126
#, kde-format
msgctxt "@title:window"
msgid "Calligra Application Not Found"
msgstr "Níor aimsíodh Feidhmchlár Calligra"

#: main.cpp:156
#, kde-format
msgid "Calligra Opener"
msgstr "Oscailteoir Calligra"

#: main.cpp:158
#, kde-format
msgid "Calligra Document Opener"
msgstr "Oscailteoir Doiciméad Calligra"

#: main.cpp:160
#, kde-format
msgid "Copyright 2010-%1 Calligra developers"
msgstr "Cóipcheart 2010-%1 Forbróirí Calligra"

#: main.cpp:161
#, kde-format
msgid "Jarosław Staniek"
msgstr "Jarosław Staniek"

#: main.cpp:168
#, kde-format
msgid "Lists names of all available Calligra applications"
msgstr "Liostaíonn sé ainmneacha na bhfeidhmchlár Calligra uile atá ar fáil"

