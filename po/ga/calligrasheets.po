msgstr ""
"Tugann an fheidhm DAYNAME() ainm an lae den tseachtain (1..7) ar ais. I "
"roinnt tíortha is é an Luan an chéad lá den tseachtain, agus i dtíortha eile "
"is é an Domhnach an chéad lá den tseachtain."

#: functions/datetime.xml:494
#, kde-format
msgid "DAYNAME(weekday)"
msgstr "AINM AN LAE (lá seachtaine)"

#: functions/datetime.xml:495
#, kde-format
msgid "DAYNAME(1) returns Monday (if the week starts on Monday)"
msgstr "Filleann DAYNAME(1) é seo: Monday (if the week starts on Monday)"

#: functions/datetime.xml:504
#, kde-format
msgid "Number of month (1..12)"
msgstr "Uimhir na míosa (1..12)"

