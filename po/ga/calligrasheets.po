msgstr "Uimhir an ró"

#: functions/reference.xml:15
#, kde-format
msgid "Column number"
msgstr "Uimhir an cholúin"

#: functions/reference.xml:19
#, kde-format
msgid "Absolute number (optional)"
msgstr "Dearbhuimhir (roghnach)"

#: functions/reference.xml:23 functions/reference.xml:160
#, kde-format
msgid "A1 style (optional)"
msgstr "Stíl A1 (roghnach)"

#: functions/reference.xml:27 ui/MapModel.cpp:144
#, kde-format
