msgstr "Is ionann NOMINAL(0.08;12) agus 0.0772"

#: functions/financial.xml:842
#, kde-format
msgid "Payment"
msgstr "Íocaíocht"

#: functions/financial.xml:850 functions/financial.xml:999
#, kde-format
msgid "Future value (FV - optional)"
msgstr "Luach cumaisc (LC - roghnach)"

#: functions/financial.xml:858
#, kde-format
msgid "Returns the number of periods of an investment."
msgstr "Tugann sé seo líon na dtréimhsí d'infheistíocht ar ais."

#: functions/financial.xml:859
#, kde-format
msgid "NPER(rate;payment;pv;fv;type)"
msgstr "NPER(ráta;íocaíocht;luachpríomhúil;luach saothair;cineál)"

#: functions/financial.xml:860
#, kde-format
