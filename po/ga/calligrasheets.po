#, kde-format
msgid "KURTP(value; value;...)"
msgstr "KURTP(luach; luach;...)"

#: functions/statistical.xml:658
#, kde-format
msgid "KURTP(A1:A5)"
msgstr "KURTP(A1:A5)"

#: functions/statistical.xml:659
#, kde-format
msgid "KURTP(21; 33; 54; 23) returns -1.021"
msgstr "Filleann KURTP(21; 33; 54; 23) é seo: -1.021"

#: functions/statistical.xml:672
#, kde-format
msgid "Position (from the largest)"
msgstr "Seasamh (ón gceann is mó)"

#: functions/statistical.xml:676
#, kde-format
msgid "The LARGE() function returns the k-th largest value from the data set."
msgstr "Tugann an fheidhm LARGE() an k-ú luach is mó ón tacar sonraí ar ais."

#: functions/statistical.xml:677
#, kde-format
