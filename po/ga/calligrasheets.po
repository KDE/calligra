msgstr "Tiontaíonn an fheidhm DATE2UNIX() luach dáta agus ama go ham Unix."

#: functions/datetime.xml:721 functions/datetime.xml:736
#, kde-format
msgid "A unix time is the number of seconds after midnight January 1st, 1970."
msgstr "Is é am unix líon na soicindí tar éis meán oíche an 1 Eanáir, 1970."

