msgstr "CURRENTDATE()"

#: functions/datetime.xml:520
#, kde-format
msgid "CURRENTDATE() returns \"Saturday 13 April 2002\""
msgstr "Filleann CURRENTDATE() é seo: \"Saturday 13 April 2002\""

#: functions/datetime.xml:530
#, kde-format
msgid "The TODAY() function returns the current date."
msgstr "Tugann an fheidhm TODAY() an dáta reatha ar ais."

#: functions/datetime.xml:531
#, kde-format
msgid "TODAY()"
msgstr "TODAY()"

#: functions/datetime.xml:532
#, kde-format
msgid "TODAY() returns \"Saturday 13 April 2002\""
msgstr "Filleann TODAY() é seo: \"Saturday 13 April 2002\""

