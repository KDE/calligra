#, kde-format
msgid "FIB(n)"
msgstr "FIB(n)"

#: functions/math.xml:1187
#, kde-format
msgid "FIB(9) returns 34"
msgstr "Filleann FIB(9) é seo: 34"

#: functions/math.xml:1188
#, kde-format
msgid "FIB(26) returns 121393"
msgstr "Filleann FIB(26) é seo: 121393"

