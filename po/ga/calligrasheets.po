msgstr "Ón aonad"

#: functions/engineering.xml:125
#, kde-format
msgid "To unit"
msgstr "Go dtí an t-aonad"

#: functions/engineering.xml:129
#, kde-format
msgid ""
"The CONVERT() function returns a conversion from one measurement system to "
"another."
msgstr ""
"Tugann an fheidhm CONVERT() tiontú ar ais ó chóras tomhais amháin go córas "
"tomhais eile."

#: functions/engineering.xml:130
#, kde-format
msgid ""
"Supported mass units: g (gram), sg (pieces), lbm (pound), u (atomic mass), "
"ozm (ounce), stone, ton, grain, pweight (pennyweight), hweight "
"(hundredweight)."
msgstr ""
"Aonaid maise a dtacaítear leo: g (gram), sg (píosaí), lbm (punt), u (mais "
"adamhach), ozm (unsa), stone, ton, grain, pweight (pennyweight), hweight "
"(céadmheáchan)."

#: functions/engineering.xml:131
#, kde-format
msgid ""
"Supported distance units: m (meter), in (inch), ft (feet), mi (mile), Nmi "
"(nautical mile), ang (Angstrom), parsec, lightyear."
msgstr ""
"Aonaid achair a dtacaítear leo: m (méadar), in (orlach), ft (troigh), mi "
"(míle), Nmi (míle farraige), ang (Angstrom), parsec, bliain solais."

#: functions/engineering.xml:132
#, kde-format
msgid ""
"Supported pressure units: Pa (Pascal), atm (atmosphere), mmHg (mm of "
"Mercury), psi, Torr."
msgstr ""
"Aonaid brú a dtacaítear leo: Pa (Pascal), atm (atmaisféar), mmHg (mm de "
"Mhearcair), psi, Torr."

#: functions/engineering.xml:133
#, kde-format
msgid "Supported force units: N (Newton), dyn, pound."
msgstr "Aonaid fórsa tacaithe: N (Niútan), dyn, punt."

#: functions/engineering.xml:134
#, kde-format
msgid ""
"Supported energy units: J (Joule), e (erg), c (Thermodynamic calorie), cal "
"(IT calorie), eV (electronvolt), HPh (Horsepower-hour), Wh (Watt-hour), flb "
"(foot-pound), BTU."
msgstr ""
"Aonaid fuinnimh a dtacaítear leo: J (Joule), e (erg), c (calraí "
"teirmidinimiciúla), cal (calraí IT), eV (leictreonvolt), HPh (Cumhacht-uair "
"an chloig), Wh (Vata-uair an chloig), flb (troigh-phunt), BTU."

#: functions/engineering.xml:135
#, kde-format
msgid "Supported power units: W (Watt), HP (horsepower), PS (Pferdestaerke)."
msgstr ""
"Aonaid chumhachta a dtacaítear leo: W (Vata), HP (each-chumhacht), PS "
"(Pferdestarke)."

#: functions/engineering.xml:136
#, kde-format
msgid "Supported magnetism units: T (Tesla), ga (Gauss)."
msgstr "Aonaid mhaighnéadais a dtacaítear leo: T (Tesla), ga (Gauss)."

#: functions/engineering.xml:137
#, kde-format
msgid "Supported temperature units: C (Celsius), F (Fahrenheit), K (Kelvin)."
msgstr ""
"Aonaid teochta a dtacaítear leo: C (Celsius), F (Fahrenheit), K (Kelvin)."

#: functions/engineering.xml:138
#, kde-format
msgid ""
"Supported volume units: l (liter), tsp (teaspoon), tbs (tablespoon), oz "
"(ounce liquid), cup, pt (pint), qt (quart), gal (gallon), barrel, m3 (cubic "
"meter), mi3 (cubic mile), Nmi3 (cubic Nautical mile), in3 (cubic inch), ft3 "
"(cubic foot), yd3 (cubic yard), GRT or regton (gross register ton)."
msgstr ""
"Aonaid toirte a dtacaítear leo: l (lítear), tsp (taespúnóg), tbs (spúnóg "
"bhoird), oz (unsa leachtach), cupán, pt (pionta), qt (ceathrú), gal (galún), "
"bairille, m3 (méadar ciúbach), mi3 (míle ciúbach), Nmi3 (míle farraige "
"ciúbach), in3 (orlach ciúbach), ft3 (troigh chiúbach), yd3 (slat chiúbach), "
"GRT nó regton (ton cláraithe comhlán)."

#: functions/engineering.xml:139
#, kde-format
msgid ""
"Supported area units: m2 (square meter), mi2 (square mile), Nmi2 (square "
"Nautical mile), in2 (square inch), ft2 (square foot), yd2 (square yard), "
"acre, ha (hectare)."
msgstr ""
"Aonaid achair a dtacaítear leo: m2 (méadar cearnach), mi2 (míle cearnach), "
"Nmi2 (míle farraige cearnach), in2 (orlach cearnach), ft2 (troigh "
"chearnach), yd2 (slat cearnach), acra, ha (heicteár)."

#: functions/engineering.xml:140
#, kde-format
msgid ""
"Supported speed units: m/s (meters per second), m/h (meters per hour), mph "
"(miles per hour), kn (knot)."
msgstr ""
"Aonaid luais a dtacaítear leo: m/s (méadair in aghaidh an tsoicind), m/u "
"(méadair san uair), mph (míle san uair), kn (snaidhm)."

#: functions/engineering.xml:141
#, kde-format
msgid ""
"For metric units any of the following prefixes can be used: E (exa, 1E+18), "
"P (peta, 1E+15), T (tera, 1E+12), G (giga, 1E+09), M (mega, 1E+06), k (kilo, "
"1E+03), h (hecto, 1E+02), e (dekao, 1E+01), d (deci, 1E-01), c (centi, "
"1E-02), m (milli, 1E-03), u (micro, 1E-06), n (nano, 1E-09), p (pico, "
"1E-12), f (femto, 1E-15), a (atto, 1E-18)."
msgstr ""
"Maidir le haonaid mhéadracha is féidir aon cheann de na réimíreanna seo a "
"leanas a úsáid: E (exa, 1E+18), P (peta, 1E+15), T (tera, 1E+12), G (giga, 1E"
"+09), M (mega, 1E+06), k (kilo, 1E+03), h (h+02), e1E + (deci, 1E-01), c "
"(centi, 1E-02), m (milli, 1E-03), u (micrea, 1E-06), n (nana, 1E-09), p "
"(pico, 1E-12), f (femto, 1E-15), a (atto, 1E-18)."

